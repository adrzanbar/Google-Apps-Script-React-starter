{
  "name": "gas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp server/appsscript.json dist/ && npx esbuild server/*.ts --outdir=dist --out-extension:.js=.gs",
    "lint": "eslint .",
    "preview": "vite preview",
    "push": "npm run build && clasp push -f",
    "create": "clasp create --type standalone --rootDir dist"
  },
