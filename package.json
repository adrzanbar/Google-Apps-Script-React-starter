  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "lint": "eslint .",
    "build": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.app.json --noEmit && vite build && cp server/appsscript.json dist/ && npx esbuild server/*.ts --outdir=dist --out-extension:.js=.gs --charset=utf8",
